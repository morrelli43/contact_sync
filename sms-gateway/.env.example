# Example .env file for sms-gateway
# Place this file in the sms-gateway directory

# Port for the SMS gateway server to listen on
PORT=4330

# API key for authenticating devices (must match device config)
SMS_GATEWAY_API_KEY=your_sms_gateway_api_key_here

# API key for authenticating with the Onyascoot Operations portal (optional, if required)
OPS_API_KEY=your_ops_api_key_here

# URL to forward incoming SMS to the web portal
WEB_PORTAL_INCOMING_URL=https://portal.onyascoot.com/api/webhooks/sms
